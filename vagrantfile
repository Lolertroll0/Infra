# Shared provisioning script for Docker
$instanciateOrchestrator = <<-SHELL
  apt-get update -y && apt-get upgrade -y
  echo "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIKvRYUIj6BxS7EC46N7DYjkdUo+1ylZrZovLB5GIuVMU" >> /home/vagrant/.ssh/authorized_keys
SHELL
$instanciateVoicePipeline = <<-SHELL
  apt-get update -y && apt-get upgrade -y
  echo "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIA1c6uW2yDcYCoXWaV0d/Ne9I5ntoARo12YMKp5T3Liq" >> /home/vagrant/.ssh/authorized_keys
SHELL

Vagrant.configure("2") do |config|
  # Global settings
  config.vm.box = "ubuntu/trusty64"
  # config.vm.box_version = "20191107.0.0"

  # VirtualBox global provider settings
  config.vm.provider "virtualbox" do |vb|
    vb.linked_clone = true # Save disk space and time by sharing the base image disk
  end

  # --- Orchestrator ---
  config.vm.define "orchestrator" do |node|
    node.vm.hostname = "orchestrator"
    node.vm.network "private_network", ip: "192.168.56.10"
    
    node.vm.provider "virtualbox" do |vb|
      vb.memory = 2048
      vb.cpus = 2
    end

    node.vm.provision "shell", inline: $instanciateOrchestrator
  end

  # --- Main Server ---
  # config.vm.define "mainServer" do |node|
  #   node.vm.hostname = "main-server"
  #   node.vm.network "private_network", ip: "192.168.56.11"
    
  #   node.vm.provider "virtualbox" do |vb|
  #     vb.memory = 8192
  #     vb.cpus = 4
  #   end
  #   # Add specific provisioning for Main Server here if needed
  # end 
    
  # --- Voice Pipeline ---
  config.vm.define "voicePipeline" do |node|
    node.vm.hostname = "voice-pipeline"
    node.vm.network "private_network", ip: "192.168.56.12"
    
    node.vm.provider "virtualbox" do |vb|
      vb.memory = 12288
      vb.cpus = 4
    end

    node.vm.provision "shell", inline: $instanciateVoicePipeline
  end
end