Vagrant.configure("2") do |config|
  config.vm.define "orchestrator" do |node|

    # Node parameters 
    node.vm.box = "debian/12-generic-amd64"
    node.vm.hostname = "Orchestrador"
    node.vm.network "private_network", ip: "192.168.56.10"
    
    node.vm.provider "virtualbox" do |vb|
      vb.memory = "2048"
      vb.cpus = 2
    end

    node.vm.provision "shell", inline: <<-SHELL
      apt-get update -y && apt-get upgrade -y
      curl -fsSL https://get.docker.com -o get-docker.sh
      sh get-docker.sh
      usermod -aG docker vagrant
      sudo systemctl enable docker
      sudo systemctl start docker
    SHELL
    end
  end

  config.vm.define "mainServer" do |node|

    # Node parameters 
    node.vm.box = "debian/12-generic-amd64"
    node.vm.hostname = "MainServer"
    node.vm.network "private_network", ip: "192.168.56.11"
    
    node.vm.provider "virtualbox" do |vb|
      vb.memory = "8192"
      vb.cpus = 4

    end
  end 
    
  config.vm.define "voicePipeline" do |node|

    # Node parameters 
    node.vm.box = "debian/12-generic-amd64"
    node.vm.hostname = "voicePipeline"
    node.vm.network "private_network", ip: "192.168.56.12"
    
    node.vm.provider "virtualbox" do |vb|
      vb.memory = "12288"
      vb.cpus = 4
    end

    node.vm.provision "shell", inline: <<-SHELL
      apt-get update -y && apt-get upgrade -y
      curl -fsSL https://get.docker.com -o get-docker.sh
      sh get-docker.sh
      usermod -aG docker vagrant
      sudo systemctl enable docker
      sudo systemctl start docker
    SHELL
    end
  end
  
end 